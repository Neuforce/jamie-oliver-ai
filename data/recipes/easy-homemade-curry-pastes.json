  "steps": [
    {
      "id": "heat_spices",
      "descr": "To make any of the above curry pastes, first peel the...",
      "instructions": "To make any of the above curry pastes, first peel the garlic and ginger. Put a frying pan on a medium to high heat and add the spices for toasting to the dry pan. Lightly toast them for a few minutes until golden brown and smelling delicious, then remove the pan from the heat.",
      "type": "immediate",
      "auto_start": true,
      "requires_confirm": true,
      "next": [
        "add_toasted"
      ],
      "on_enter": [
        {
          "say": "To make any of the above curry pastes, first peel the garlic and ginger. Put a frying pan on a medium to high heat and add the spices for toasting to the dry pan. Lightly toast them for a few minutes until golden brown and smelling delicious, then remove the pan from the heat."
        }
      ]
    },
    {
      "id": "add_toasted",
      "descr": "Add the toasted spices to a pestle and mortar and grind...",
      "instructions": "Add the toasted spices to a pestle and mortar and grind until fine, or put them into a food processor and whiz to a powder. Either way, when you\u2019ve ground them whiz the toasted spices in a food processor with the rest of the ingredients and \u00bd a teaspoon of sea salt until you have a smooth paste.",
      "type": "immediate",
      "auto_start": false,
      "requires_confirm": false,
      "depends_on": [
        "heat_spices"
      ],
      "on_enter": [
        {
          "say": "Add the toasted spices to a pestle and mortar and grind until fine, or put them into a food processor and whiz to a powder. Either way, when you\u2019ve ground them whiz the toasted spices in a food processor with the rest of the ingredients and \u00bd a teaspoon of sea salt until you have a smooth paste."
        }
      ]
    }
