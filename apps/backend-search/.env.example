# Backend-Search Environment Variables
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
PYTHON_VERSION=3.11

# NeuGate query gate (fail-safe: off or error → proceed without blocking)
NEUGATE_ENABLED=false
NEUGATE_URL=http://localhost:8080
NEUGATE_API_KEY=
NEUGATE_PROJECT_ID=jamie-oliver-ai
NEUGATE_TIMEOUT_SECONDS=0.8

# Optional: Voice chat (WebSocket)
DEEPGRAM_API_KEY=your-deepgram-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
