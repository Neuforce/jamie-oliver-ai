# Backend-Search Environment Variables
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
PYTHON_VERSION=3.11

# NeuGate query gate. Omit NEUGATE_ENABLED or set false = bypass NeuGate HTTP (code default: false).
# When NeuGate is on, errors/timeouts → proceed without blocking (fail-safe).
NEUGATE_ENABLED=false
NEUGATE_URL=http://localhost:8080
NEUGATE_API_KEY=
NEUGATE_PROJECT_ID=jamie-oliver-ai
NEUGATE_TIMEOUT_SECONDS=0.8
# When NeuGate errors, run conservative substring fallback before allowing proceed (default true).
NEUGATE_INLINE_FALLBACK_ON_ERROR=true

# Optional: Voice chat (WebSocket)
DEEPGRAM_API_KEY=your-deepgram-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
STT_LANGUAGE=en-US
STT_MODEL=nova-3
# Generic Deepgram live tuning (set false to disable)
STT_SMART_FORMAT=true
STT_PUNCTUATE=true
STT_NUMERALS=true
STT_INTERIM_RESULTS=true
STT_UTTERANCE_END_MS=900
STT_ENDPOINTING_MS=450

# Supertab agentic payments
# Customer client id — must match VITE_SUPERTAB_CLIENT_ID on the frontend
SUPERTAB_CLIENT_ID=test_client.your-site-client-id
SUPERTAB_MAPI_CLIENT_ID=live_client.your_mapi_client_id
SUPERTAB_MAPI_CLIENT_SECRET=your_mapi_client_secret
# From Supertab Business Portal → Webhooks after registering:
#   https://<backend-host>/api/v1/webhooks/supertab
SUPERTAB_WEBHOOK_SECRET=whsec_your_svix_signing_secret
