# Frontend Environment Variables
VITE_WS_URL=ws://localhost:8100/ws/voice
# Required in production (e.g. Vercel): public URL of backend-search (Railway), no trailing slash
VITE_API_BASE_URL=http://localhost:8000
# Set true only if you intentionally want bundled public/recipes-json when the API fails (default: dev-only fallback)
# VITE_ALLOW_LOCAL_RECIPES=true
VITE_AUDIO_CAPTURE_ENGINE=auto
VITE_VOICE_BARGE_IN_ENABLED=true
VITE_SUPERTAB_CLIENT_ID=test_client.your-client-id
VITE_SUPERTAB_PAYWALL_EXPERIENCE_ID=experience.your-paywall-id
VITE_SUPERTAB_PURCHASE_BUTTON_EXPERIENCE_ID=experience.your-purchase-button-id
