# Backend-Voice Environment Variables
OPENAI_API_KEY=sk-your-openai-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=vinj1qyMFj0KgswzTjUi
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
STT_LANGUAGE=en-US
STT_MODEL=nova-3
# Generic Deepgram live tuning (set false to disable)
STT_SMART_FORMAT=true
STT_PUNCTUATE=true
STT_NUMERALS=true
STT_INTERIM_RESULTS=true
STT_UTTERANCE_END_MS=1000
STT_ENDPOINTING_MS=200
HOST=0.0.0.0
PORT=8100
ENVIRONMENT=development
RECIPES_SOURCE=local
RECIPES_DIR=../../data/recipes

# NeuGate (optional; mirrors backend-search discovery guardrails)
# Omit NEUGATE_ENABLED or set false = bypass NeuGate HTTP (default in code: false)
NEUGATE_ENABLED=false
NEUGATE_URL=http://localhost:8080
NEUGATE_API_KEY=
NEUGATE_PROJECT_ID=jamie-oliver-ai
NEUGATE_TIMEOUT_SECONDS=0.8
NEUGATE_INLINE_FALLBACK_ON_ERROR=true
# FR-5 (Should): re-check assistant text with NeuGate before ElevenLabs (only if NEUGATE_ENABLED=true).
# NEUGATE_OUTPUT_MODERATION_ENABLED=false
# Skip moderation for very short TTS chunks (per sentence) to limit latency and API calls.
# NEUGATE_OUTPUT_MODERATION_MIN_CHARS=24
