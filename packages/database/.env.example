# Proyecto Supabase: reemplazá YOUR_PROJECT_REF y YOUR_DATABASE_PASSWORD.
# Postgres directo: host db.YOUR_PROJECT_REF.supabase.co (no el dominio solo del ref).

DATABASE_URL="postgresql://postgres:YOUR_DATABASE_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:YOUR_DATABASE_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Si la contraseña tiene @, :, $, etc., usá codificación porcentual en la URI.
