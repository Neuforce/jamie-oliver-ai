# Copy to .env (gitignored) and fill in. Create the key in https://business.supertab.co -> API Keys.
SUPERTAB_MAPI_CLIENT_ID=live_client.your-api-key-client-id
SUPERTAB_MAPI_CLIENT_SECRET=your-api-key-secret

# Optional: the x-supertab-client-id header value (the Site Client ID).
# Defaults to SUPERTAB_MAPI_CLIENT_ID if unset.
# SUPERTAB_CLIENT_ID=test_client.your-site-client-id
